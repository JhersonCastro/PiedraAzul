@page "/admin/agenda"
@* @inject GrpcAppointmentService AppointmentService *@

<div class="min-h-screen bg-slate-50 p-8">
    <div class="max-w-7xl mx-auto">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-slate-900">Agenda Médica</h1>
                <p class="text-slate-500 mt-1">Gestión y listado de citas de los especialistas</p>
            </div>
            
            <button class="bg-teal-800 hover:bg-teal-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Agendar Manualmente
            </button>
        </div>

        <!-- Filtros -->
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Especialista</label>
                <select class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50">
                    <option value="">Selecciona un médico...</option>
                    <option value="1">Dr. Roberto Gómez (Quiropraxia)</option>
                    <option value="2">Dra. Ana Martínez (Terapia Neural)</option>
                </select>
            </div>
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Fecha</label>
                <input type="date" class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" />
            </div>

            <div class="flex items-end">
                <button class="w-full bg-slate-800 hover:bg-slate-900 text-white px-4 py-2.5 rounded-lg font-medium transition-colors shadow-sm">
                    Filtrar Agenda
                </button>
            </div>
        </div>

        <!-- Tabla de Citas -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Hora</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Paciente</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Motivo/Servicio</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                            <th class="py-4 px-6 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        <!-- Item de Ejemplo 1 -->
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-4 px-6">
                                <div class="font-semibold text-slate-800">08:00 AM</div>
                                <div class="text-xs text-slate-500">30 min</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-medium text-slate-900">Carlos Arturo López</div>
                                <div class="text-sm text-slate-500">ID: 1061234567 • +57 311 234 5678</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="inline-flex px-3 py-1 rounded-full bg-blue-50 text-blue-700 text-xs font-medium">Quiropraxia</div>
                            </td>
                            <td class="py-4 px-6">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-emerald-50 text-emerald-700 text-xs font-medium border border-emerald-200/50">
                                    <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                    Confirmada
                                </span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <button class="text-teal-600 hover:text-teal-800 font-medium text-sm transition-colors mr-3">Ver Detalle</button>
                                <button class="text-rose-500 hover:text-rose-700 font-medium text-sm transition-colors">Cancelar</button>
                            </td>
                        </tr>

                        <!-- Item de Ejemplo 2 -->
                        <tr class="hover:bg-slate-50/50 transition-colors">
                            <td class="py-4 px-6">
                                <div class="font-semibold text-slate-800">09:00 AM</div>
                                <div class="text-xs text-slate-500">45 min</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="font-medium text-slate-900">María Elena Torres</div>
                                <div class="text-sm text-slate-500">ID: 1067654321 • +57 310 987 6543</div>
                            </td>
                            <td class="py-4 px-6">
                                <div class="inline-flex px-3 py-1 rounded-full bg-purple-50 text-purple-700 text-xs font-medium">Terapia Neural</div>
                            </td>
                            <td class="py-4 px-6">
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-amber-50 text-amber-700 text-xs font-medium border border-amber-200/50">
                                    <span class="w-1.5 h-1.5 rounded-full bg-amber-500"></span>
                                    Pendiente
                                </span>
                            </td>
                            <td class="py-4 px-6 text-right">
                                <button class="text-teal-600 hover:text-teal-800 font-medium text-sm transition-colors mr-3">Ver Detalle</button>
                                <button class="text-rose-500 hover:text-rose-700 font-medium text-sm transition-colors">Cancelar</button>
                            </td>
                        </tr>
                        
                    </tbody>
                </table>
            </div>
            
            <!-- Paginación Mock -->
            <div class="p-4 border-t border-slate-100 flex items-center justify-between text-sm text-slate-500">
                <div>Mostrando 1 a 2 de 12 citas</div>
                <div class="flex gap-2">
                    <button class="px-3 py-1 rounded bg-slate-100 hover:bg-slate-200 transition-colors disabled:opacity-50" disabled>Anterior</button>
                    <button class="px-3 py-1 rounded bg-slate-100 hover:bg-slate-200 transition-colors">Siguiente</button>
                </div>
            </div>
        </div>

    </div>
</div>

