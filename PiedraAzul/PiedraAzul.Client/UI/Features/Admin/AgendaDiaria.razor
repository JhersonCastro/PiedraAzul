@page "/admin/agenda"
@* @inject GrpcAppointmentService AppointmentService *@

<div class="min-h-screen bg-slate-50 p-8">
    <div class="max-w-7xl mx-auto">
        
        <!-- Header -->
        <div class="flex items-center justify-between mb-8">
            <div>
                <h1 class="text-3xl font-bold text-teal-900">Agenda Médica</h1>
                <p class="text-slate-500 mt-1">Gestión y listado de citas de los especialistas</p>
            </div>
            
            <button class="bg-teal-600 hover:bg-teal-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
                </svg>
                Agendar Manualmente
            </button>
        </div>

        <!-- Filtros -->
        <div class="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Especialista</label>
                <select class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50">
                    <option value="">Selecciona un médico...</option>
                    <option value="1">Dr. Roberto Gómez (Quiropraxia)</option>
                    <option value="2">Dra. Ana Martínez (Terapia Neural)</option>
                </select>
            </div>
            
            <div>
                <label class="block text-sm font-semibold text-slate-700 mb-2">Fecha</label>
                <input type="date" class="w-full bg-slate-50 border border-slate-200 text-slate-700 rounded-lg px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-teal-500/50" />
            </div>

            <div class="flex items-end">
                <button class="w-full bg-slate-800 hover:bg-slate-900 text-white px-4 py-2.5 rounded-lg font-medium transition-colors shadow-sm">
                    Filtrar Agenda
                </button>
            </div>
        </div>

        
</div>

@code {

}
