@page "/servicios/exportar-citas"
@layout PiedraAzul.Client.UI.Shared.Layout.EmptyLayout
@using PiedraAzul.Client.Models.GraphQL
@using PiedraAzul.Client.States
@using PiedraAzul.Client.Services.GraphQLServices
@using PiedraAzul.Contracts.Enums
@using System.Text
@inject UserState UserState
@inject NavigationManager NavigationManager
@inject GraphQLAppointmentService AppointmentService
@inject GraphQLDoctorService DoctorService
@inject IJSRuntime JS

<div class="min-h-screen bg-slate-50 pb-12">
    
    <!-- HEADER / NAV (Standard shared header) -->
    <header class="bg-white border-b sticky top-0 z-30">
        <div class="max-w-7xl mx-auto px-4 h-20 flex items-center justify-between">
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-3">
                    <div class="bg-primary p-2 rounded-lg text-white">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                    </div>
                    <span class="text-xl font-bold text-slate-800">Piedra Azul</span>
                </div>
                <nav class="hidden md:flex items-center gap-8">
                    @if (IsAdmin) { <a href="/admin" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Admin</a> }
                    @if (IsDoctor) { <a href="/doctor" class="text-slate-500 font-medium hover:text-slate-900 transition-colors">Dashboard</a> }
                    <span class="text-slate-900 font-semibold border-b-2 border-primary py-7">Exportar</span>
                </nav>
            </div>
            <div class="flex items-center gap-6">
                <!-- User Profile -->
                <div class="flex items-center gap-3 pl-6 border-l">
                    <div class="text-right hidden sm:block">
                        <div class="text-sm font-bold text-slate-900">@UserState?.User?.Name</div>
                        <div class="text-xs text-slate-400">@UserState?.User?.Roles.FirstOrDefault()</div>
                    </div>
                    <img src="https://ui-avatars.com/api/?name=@UserState?.User?.Name&background=257D8D&color=fff" alt="User" class="w-10 h-10 rounded-full border-2 border-slate-100" />
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 mt-12">
        
        <!-- Page Title & Back -->
        <div class="flex items-start gap-6 mb-10">
            <button @onclick="GoBack" class="mt-1 bg-white p-3 rounded-xl border border-slate-200 shadow-sm hover:bg-slate-50 transition-all text-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <div>
                <h1 class="text-4xl font-black text-slate-900 mb-2">Exportación de Citas (CSV)</h1>
                <p class="text-slate-500 text-lg font-medium">Prepare su consulta offline descargando el listado del día</p>
            </div>
        </div>

        <!-- Filters Section -->
        <div class="bg-white rounded-[2rem] p-8 shadow-sm border border-slate-100 mb-8">
            <div class="flex items-center gap-3 mb-8">
                <div class="text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
                </div>
                <h2 class="text-xl font-bold text-slate-900">Filtros de Exportación</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div>
                    <label class="block text-slate-500 font-bold uppercase tracking-wider text-xs mb-3 ml-1">MÉDICO / TERAPISTA</label>
                    <div class="relative">
                        <select @bind="SelectedDoctorId" @bind:after="CargarCitas" disabled="@(!CanSelectDoctor)" 
                                class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-4 px-6 focus:outline-none focus:ring-4 focus:ring-primary/10 transition-all text-slate-700 font-medium appearance-none">
                            <option value="">Seleccione un profesional...</option>
                            @foreach (var doc in doctores)
                            {
                                <option value="@doc.UserId">@doc.Name (@doc.Specialty)</option>
                            }
                        </select>
                        <div class="absolute inset-y-0 right-6 flex items-center pointer-events-none text-slate-400">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-slate-500 font-bold uppercase tracking-wider text-xs mb-3 ml-1">FECHA DE CITAS</label>
                    <input type="date" @bind="SelectedDate" @bind:after="CargarCitas"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl py-4 px-6 focus:outline-none focus:ring-4 focus:ring-primary/10 transition-all text-slate-700 font-medium" />
                </div>
            </div>
        </div>

        <!-- Preview Section -->
        <div class="bg-white rounded-[2rem] shadow-sm border border-slate-100 overflow-hidden mb-8">
            <div class="px-8 py-6 bg-slate-50/30 flex items-center justify-between border-b border-slate-100">
                <h3 class="text-xl font-bold text-slate-900">Vista Previa de Exportación</h3>
                <span class="bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-bold tracking-tight">@citas.Count citas encontradas</span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full border-collapse text-left">
                    <thead>
                        <tr class="border-b border-slate-50 bg-slate-50/20 text-slate-400 font-bold uppercase tracking-[0.1em] text-[10px]">
                            <th class="px-8 py-5">PACIENTE</th>
                            <th class="px-8 py-5">HORARIO</th>
                            <th class="px-8 py-5">TIPO</th>
                            <th class="px-8 py-5">ESTADO</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @if (!citas.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-8 py-10 text-center text-slate-400 italic">No se encontraron citas para los filtros seleccionados.</td>
                            </tr>
                        }
                        @foreach (var app in citas.OrderBy(a => a.Start))
                        {
                            <tr class="text-slate-700 font-medium hover:bg-slate-50/50 transition-colors">
                                <td class="px-8 py-5 font-bold text-slate-900">@app.PatientName</td>
                                <td class="px-8 py-5 text-slate-500 font-mono">@app.Start.ToString("hh:mm tt")</td>
                                <td class="px-8 py-5 text-slate-500 text-xs uppercase font-bold">@app.PatientType</td>
                                <td class="px-8 py-5">
                                    <span class="inline-flex items-center gap-2 px-3 py-1 bg-emerald-50 text-emerald-600 rounded-lg text-xs font-bold">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
                                        Confirmada
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-end gap-4 mb-10">
            <button @onclick="PrintList" disabled="@(!citas.Any())" 
                    class="w-full sm:w-auto flex items-center justify-center gap-3 bg-white border-2 border-slate-100 px-10 py-4 rounded-2xl font-bold text-slate-600 hover:bg-slate-50 transition-all disabled:opacity-50">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect width="12" height="8" x="6" y="14"/></svg>
                Imprimir Listado
            </button>
            <button @onclick="ExportCSV" disabled="@(!citas.Any())"
                    class="w-full sm:w-auto flex items-center justify-center gap-3 bg-primary text-white px-10 py-4 rounded-2xl font-bold hover:opacity-90 transition-all shadow-xl shadow-primary/30 disabled:opacity-50">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Exportar a CSV
            </button>
        </div>

        <!-- Info Banner -->
        <div class="bg-blue-50/50 border border-blue-100 rounded-3xl p-8 flex items-start gap-6">
            <div class="text-blue-500 mt-1">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </div>
            <p class="text-blue-900/70 font-medium leading-relaxed">
                El archivo CSV es compatible con Excel, Google Sheets y Numbers. Incluye datos de contacto del paciente para su uso en emergencias offline.
            </p>
        </div>

        <footer class="mt-20 py-8 border-t border-slate-100 text-center">
            <p class="text-slate-400 font-bold uppercase tracking-widest text-[11px]">PIEDRA AZUL - SISTEMA DE GESTIÓN MÉDICA</p>
        </footer>

    </main>
</div>

@code {
    private string SelectedDoctorId { get; set; } = "";
    private DateTime SelectedDate { get; set; } = DateTime.Today;
    private List<DoctorGQL> doctores = new();
    private List<AppointmentGQL> citas = new();

    private bool IsAdmin => UserState?.User?.Roles.Contains("Admin") == true;
    private bool IsDoctor => UserState?.User?.Roles.Contains("Doctor") == true;
    private bool IsAgendador => UserState?.User?.Roles.Contains("Agendador") == true;
    private bool CanSelectDoctor => IsAdmin || IsAgendador;

    protected override async Task OnInitializedAsync()
    {
        if (UserState.User == null) return;

        if (CanSelectDoctor)
        {
            // Cargar todos los tipos de doctores
            foreach (DoctorType type in Enum.GetValues(typeof(DoctorType)))
            {
                var result = await DoctorService.GetDoctorsByTypeAsync(type.ToGraphQL());
                if (result != null)
                {
                    foreach(var d in result)
                    {
                        if (!doctores.Any(x => x.UserId == d.UserId))
                            doctores.Add(d);
                    }
                }
            }
        }
        else if (IsDoctor)
        {
            // Si es doctor, debe verse a sí mismo en la lista
            var docResult = await DoctorService.GetDoctorAsync(UserState.User.Id);
            if (docResult.IsSuccess && docResult.Value != null)
            {
                doctores.Add(docResult.Value);
                SelectedDoctorId = docResult.Value.UserId;
            }
            else
            {
                // Fallback con datos del usuario si el servicio de perfiles falla
                doctores.Add(new DoctorGQL { UserId = UserState.User.Id, Name = UserState.User.Name, Specialty = "Médico" });
                SelectedDoctorId = UserState.User.Id;
            }
            
            await CargarCitas();
        }
    }

    private async Task CargarCitas()
    {
        if (string.IsNullOrEmpty(SelectedDoctorId)) return;

        var result = await AppointmentService.GetDoctorAppointments(SelectedDoctorId, SelectedDate);
        if (result.IsSuccess && result.Value != null)
        {
            citas = result.Value;
        }
        else
        {
            citas = new();
        }
    }

    private async Task ExportCSV()
    {
        if (!citas.Any()) return;

        var csv = new StringBuilder();
        csv.AppendLine("Paciente;Horario;Tipo;Estado;CreadaEn");

        foreach (var app in citas.OrderBy(a => a.Start))
        {
            csv.AppendLine($"{app.PatientName};{app.Start:HH:mm};{app.PatientType};Confirmada;{app.CreatedAt:yyyy-MM-dd HH:mm}");
        }

        var fileName = $"Citas_{SelectedDate:yyyyMMdd}_{SelectedDoctorId}.csv";
        await JS.InvokeVoidAsync("downloadFile", fileName, "text/csv", csv.ToString());
    }

    private async Task PrintList()
    {
        await JS.InvokeVoidAsync("window.print");
    }

    private void GoBack()
    {
        if (IsAdmin) NavigationManager.NavigateTo("/admin");
        else if (IsDoctor) NavigationManager.NavigateTo("/doctor");
        else NavigationManager.NavigateTo("/");
    }
}
